# IP-Adresse des Windows-Servers mit der Freigabe (z.B. 10.10.20.32)
SHARE_IP=
# Name der Windows-Freigabe (z.B. Zertifikate)
SHARE_NAME=
# Unterordner auf der Freigabe fuer die Zertifikate (z.B. Loeschzertifikate)
SHARE_PATH=
# Windows-Benutzername fuer die Freigabe (leer = Gastzugriff)
SHARE_USER=
# Windows-Passwort fuer die Freigabe (leer = Gastzugriff)
SHARE_PASS=
# Statische Fallback-IP falls kein DHCP verfuegbar (z.B. 192.168.1.200)
FALLBACK_IP=
# Subnetz-Prefix fuer die Fallback-IP (z.B. 24 = 255.255.255.0)
FALLBACK_PREFIX=
