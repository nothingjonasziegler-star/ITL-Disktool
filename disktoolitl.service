[Unit]
Description=DiskToolITL 2.0 - Disk-Wipe-System
After=network.target udev.service
Wants=network.target

[Service]
Type=simple
ExecStart=/bin/bash /opt/disktoolitl/disktoolitl.sh
WorkingDirectory=/opt/disktoolitl
Restart=always
RestartSec=5
User=root
Environment="LANG=C.UTF-8"
Environment="LC_ALL=C.UTF-8"
StandardOutput=append:/opt/disktoolitl/logs/disktoolitl.log
StandardError=append:/opt/disktoolitl/logs/disktoolitl.log

[Install]
WantedBy=multi-user.target
